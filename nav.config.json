<h1>Listado de Encuestas</h1>

<table>

<thead>

<tr>

<th>ID</th>
<th>Titulo</th>
<th>Descripcion</th>
<th>Fecha</th>
<th>Activa</th>

<th>
<a href="index.php?page=Mantenimientos-Encuestas-Formulario&mode=INS&id=0">
Nueva
</a>
</th>

</tr>

</thead>

<tbody>

{{foreach encuestas}}

<tr>

<td>{{encuesta_id}}</td>
<td>{{titulo}}</td>
<td>{{descripcion}}</td>
<td>{{fecha}}</td>
<td>{{activa}}</td>

<td>

<a href="index.php?page=Mantenimientos-Encuestas-Formulario&mode=DSP&id={{encuesta_id}}">
Mostrar
</a>

<br>

<a href="index.php?page=Mantenimientos-Encuestas-Formulario&mode=UPD&id={{encuesta_id}}">
Editar
</a>

<br>

<a href="index.php?page=Mantenimientos-Encuestas-Formulario&mode=DEL&id={{encuesta_id}}">
Eliminar
</a>

</td>

</tr>

{{endfor encuestas}}

</tbody>

</table>

